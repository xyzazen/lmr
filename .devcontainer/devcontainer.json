{
  "name": "Lumarge Web",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:18",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y lua5.4 && bash setup.sh",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Lumarge Web",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["sumneko.lua"]
    }
  }
}
